# URL of the Meow Circle Go backend. Expo exposes any var prefixed with
# EXPO_PUBLIC_ to the client bundle, so this is what src/api.ts reads.
#
# Local dev (server running on your machine via `make run`):
#   - iOS simulator: http://localhost:8080
#   - Android emulator: http://10.0.2.2:8080  (10.0.2.2 is host-from-emulator)
#   - Real device on same Wi-Fi: http://<your-lan-ip>:8080
#
EXPO_PUBLIC_API_URL=http://localhost:8080
